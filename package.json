{
  "name": "drbtaskforce",
  "version": "1.0.0",
  "description": "DRBTaskforce community hub for $DRB token on Base",
  "scripts": {
    "css:build": "postcss src/assets/css/tailwind.css -o src/assets/css/main.css",
    "css:watch": "postcss src/assets/css/tailwind.css -o src/assets/css/main.css --watch",
    "dev": "npm run css:build && eleventy --serve & npm run css:watch",
    "build": "npm run css:build && eleventy",
    "clean": "rm -rf _site"
  },
  "keywords": [
    "drb",
    "debtreliefbot",
    "crypto",
    "base"
  ],
  "author": "DRBTaskforce",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "tailwindcss": "^3.4.19"
  }
}
